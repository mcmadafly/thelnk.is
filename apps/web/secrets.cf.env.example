# Copy to secrets.cf.env (gitignored) and set real values, then:
#   bunx wrangler secret bulk secrets.cf.env
#
# Only put Worker *secrets* here — not vars already in wrangler.jsonc (e.g. R2_ACCOUNT_ID, R2_BUCKET_NAME, PUBLIC_* origins).
#
# Do not bulk-upload lines with empty values (KEY= with nothing after =). Cloudflare
# stores those as empty strings; Clerk then sees CLERK_SECRET_KEY as set but invalid
# and the site returns 500. Omit a key until it has a value, or use `wrangler secret put`.

CLERK_SECRET_KEY=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
