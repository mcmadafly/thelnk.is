{
	// D1 + R2 `remote: true`: `astro dev` uses production bindings. Requires CLOUDFLARE_API_TOKEN in env (see apps/web/.env).
	// `astro build` sets `remoteBindings: false` in `astro.config.mjs` so deploy/CI skip edge-preview auth.
	// Caution: `wrangler d1 migrations apply` affects this database — confirm flags/env before running migrations locally.
	"compatibility_date": "2026-05-12",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"name": "thelnk-web",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "thelnk",
			"database_id": "23bf7d86-e447-4fc3-8f64-3881ae393649",
			"migrations_dir": "migrations",
			"remote": true
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "aa5f255656564e2eb00e870d228467b4"
		}
	],
	"r2_buckets": [
		{
			"binding": "FILES",
			"bucket_name": "thelnk",
			"remote": true
		}
	],
	"vars": {
		"R2_ACCOUNT_ID": "9acf5bdc7c2c3d46f02c207c438bc7a0",
		"R2_BUCKET_NAME": "thelnk",
		"PUBLIC_APP_ORIGIN": "https://thelnk.is",
		"PUBLIC_SHORT_ORIGIN": "https://thelnk.is",
		"FORCE_PRO": "false",
		"PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_live_Y2xlcmsudGhlbG5rLmlzJA"
	}
}