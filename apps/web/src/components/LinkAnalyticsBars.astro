---
interface Props {
  points: number[];
  total?: number;
  locked?: boolean;
  periodLabel?: string;
}

const { points = [], total = 0, locked = false, periodLabel = '14d' } = Astro.props;
const max = points.length ? Math.max(...points, 1) : 1;
const columns = Math.max(1, points.length || 1);
---

{locked ? (
  <div class="analytics-locked">
    <span>Upgrade to view analytics</span>
  </div>
) : (
  <div class="analytics-wrap" title={`${periodLabel} · ${total} events`}>
    <div class="analytics-bars" aria-hidden="true" style={`--analytics-columns:${columns}`}>
      {points.map((v) => {
        const h = Math.max(8, Math.round((v / max) * 100));
        return <span class="analytics-bar" style={`height:${h}%`} data-value={String(v)}></span>;
      })}
    </div>
    <small>{periodLabel}: {total}</small>
  </div>
)}

<style>
  .analytics-wrap {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .analytics-bars {
    display: grid;
    grid-template-columns: repeat(var(--analytics-columns, 14), minmax(0, 1fr));
    align-items: end;
    gap: 2px;
    width: 108px;
    height: 26px;
    padding: 2px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
  }
  .analytics-bar {
    display: block;
    min-height: 3px;
    background: rgba(255, 229, 0, 0.9);
    opacity: 0.88;
  }
  .analytics-wrap small {
    color: var(--muted);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .analytics-locked {
    display: inline-flex;
    align-items: center;
    border: 1px dashed rgba(255, 229, 0, 0.38);
    color: var(--muted);
    font-size: 0.64rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.42rem;
    white-space: nowrap;
  }
</style>
