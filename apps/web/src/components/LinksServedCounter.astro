---
import {
  LINKS_SERVED_GAG_MILLIONS,
  LINKS_SERVED_TICKER_MIN_WIDTH,
  formatTickerLabel,
  tickerGagStartValue,
} from '../lib/links-served-ticker';

interface Props {
  count: number;
}

const { count } = Astro.props;
const width = LINKS_SERVED_TICKER_MIN_WIDTH;
const gagValue = tickerGagStartValue(LINKS_SERVED_GAG_MILLIONS, width);
const startLabel = formatTickerLabel(gagValue, width);
const finalLabel = formatTickerLabel(count, width);
---

<section class="links-served" id="links-served" aria-labelledby="links-served-title">
  <h2 id="links-served-title" class="sr-only">Links served</h2>
  <p class="links-served-line">
    <span
      class="links-served-num"
      data-links-served-counter
      data-start={gagValue}
      data-end={count}
      data-width={width}
    >{startLabel}</span><span class="links-served-label"> links served to date</span>
  </p>
</section>

<script>
  import { formatTickerLabel } from '../lib/links-served-ticker';

  function easeOutCubic(t: number): number {
    return 1 - (1 - t) ** 3;
  }

  function runCounter(): void {
    const el = document.querySelector<HTMLElement>('[data-links-served-counter]');
    if (!el) return;

    const start = Number.parseInt(el.getAttribute('data-start') ?? '0', 10);
    const end = Number.parseInt(el.getAttribute('data-end') ?? '0', 10);
    const width = Number.parseInt(el.getAttribute('data-width') ?? '6', 10);
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced || start <= end) {
      el.textContent = formatTickerLabel(end, width);
      return;
    }

    const duration = 2800;
    const t0 = performance.now();

    const tick = (now: number) => {
      const t = Math.min(1, (now - t0) / duration);
      const value = Math.round(start + (end - start) * easeOutCubic(t));
      el.textContent = formatTickerLabel(value, width);
      if (t < 1) requestAnimationFrame(tick);
      else el.textContent = formatTickerLabel(end, width);
    };

    requestAnimationFrame(tick);
  }

  const section = document.getElementById('links-served');
  if (!section) {
    runCounter();
  } else {
    const obs = new IntersectionObserver(
      (entries) => {
        if (!entries.some((e) => e.isIntersecting)) return;
        obs.disconnect();
        runCounter();
      },
      { threshold: 0.2 },
    );
    obs.observe(section);
  }
</script>

<style>
  .links-served {
    border-top: 1px solid var(--border);
    padding: 2.25rem 6vw;
    text-align: center;
  }

  .links-served-line {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0 0.4em;
    font-family: var(--serif);
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .links-served-num {
    font-family: var(--mono);
    font-size: 1em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .links-served-label {
    color: var(--muted);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.04em;
  }

  @media (max-width: 768px) {
    .links-served {
      padding: 1.75rem 1.5rem;
    }
  }
</style>
