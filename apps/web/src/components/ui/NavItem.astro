---
import Icon from './Icon.astro';

interface Props {
  href: string;
  label: string;
  icon: string;
  active?: boolean;
  disabled?: boolean;
}
const { href, label, icon, active = false, disabled = false } = Astro.props;
const base = 'flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-colors';
const stateCls = active
  ? 'bg-sidebar-accent text-sidebar-accent-foreground'
  : 'text-muted-foreground hover:bg-sidebar-accent hover:text-foreground';
---
{disabled ? (
  <span class={`${base} cursor-default text-muted-foreground/50`} aria-disabled="true">
    <Icon name={icon} size={18} />
    <span>{label}</span>
    <span class="ml-auto rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">Soon</span>
  </span>
) : (
  <a href={href} class={`${base} ${stateCls}`} aria-current={active ? 'page' : undefined}>
    <Icon name={icon} size={18} />
    <span>{label}</span>
  </a>
)}
