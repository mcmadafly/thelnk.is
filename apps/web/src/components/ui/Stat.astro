---
import Icon from './Icon.astro';

interface Props {
  label: string;
  value: string;
  delta?: string;
  trend?: 'up' | 'down';
  icon?: string;
}
const { label, value, delta, trend, icon } = Astro.props;
const trendColor = trend === 'up' ? 'text-emerald-500' : trend === 'down' ? 'text-destructive' : 'text-muted-foreground';
---
<div>
  <div class="flex items-center gap-1.5 text-sm text-muted-foreground">
    {icon && <Icon name={icon} size={15} />}
    <span>{label}</span>
  </div>
  <div class="mt-1 flex items-baseline gap-2">
    <span class="text-2xl font-semibold tracking-tight tabular-nums">{value}</span>
    {delta && (
      <span class={`inline-flex items-center gap-0.5 text-xs font-medium ${trendColor}`}>
        {trend && <Icon name={trend === 'up' ? 'trendingUp' : 'trendingDown'} size={13} />}
        {delta}
      </span>
    )}
  </div>
</div>
