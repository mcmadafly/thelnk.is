---
import type { WallOfFameData, WallOfFameEntry } from '../lib/wall-of-fame';
import { PREVIEW_VIEWPORT_HEIGHT, PREVIEW_VIEWPORT_WIDTH } from '../lib/microlink-preview';

interface Props {
  data: WallOfFameData;
}

const { data } = Astro.props;

if (!data.featured.length) {
  return null;
}

function statLabel(entry: { linkCount?: number }): string {
  const n = entry.linkCount ?? 1;
  return n === 1 ? '1 link' : `${n} links`;
}

function chromeUrl(entry: WallOfFameEntry): string {
  const host = entry.hostname;
  if (!entry.title || entry.title === host) return `https://${host}`;
  if (entry.title.startsWith('http://') || entry.title.startsWith('https://')) return entry.title;
  return `https://${entry.title}`;
}
---

<section class="wall-of-fame" id="wall-of-fame" aria-labelledby="wall-of-fame-title">
  <div class="wall-of-fame-header">
    <h2 id="wall-of-fame-title" class="section-title">Wall of fame</h2>
    <p class="wall-of-fame-sub">Top destinations by how many lnks point there.</p>
  </div>

  <div class="wof-featured" role="list">
    {data.featured.map((entry) => (
      <article class="wof-card wof-card--featured" role="listitem">
        <a class="wof-card-link" href={entry.shortUrl} target="_blank" rel="noopener noreferrer">
          <div class="wof-browser" aria-hidden="true">
            <div class="wof-browser-chrome">
              <div class="wof-browser-dots"><span></span><span></span><span></span></div>
              <span class="wof-browser-url">{chromeUrl(entry)}</span>
            </div>
            <div class="wof-shot">
              <img
                src={entry.previewUrl}
                alt=""
                width={PREVIEW_VIEWPORT_WIDTH}
                height={PREVIEW_VIEWPORT_HEIGHT}
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
          <div class="wof-card-meta">
            <span class="wof-host">{entry.hostname}</span>
            <span class="wof-stat">{statLabel(entry)}</span>
          </div>
        </a>
      </article>
    ))}
  </div>

  {data.more.length > 0 && (
    <div class="wof-more" role="list">
      {data.more.map((entry) => (
        <article class="wof-card wof-card--more" role="listitem">
          <a class="wof-card-link" href={entry.shortUrl} target="_blank" rel="noopener noreferrer">
            <div class="wof-browser wof-browser--compact" aria-hidden="true">
              <div class="wof-browser-chrome">
                <div class="wof-browser-dots"><span></span><span></span><span></span></div>
                <span class="wof-browser-url">{chromeUrl(entry)}</span>
              </div>
              <div class="wof-shot">
                <img
                  src={entry.previewUrl}
                  alt=""
                  width={PREVIEW_VIEWPORT_WIDTH}
                  height={PREVIEW_VIEWPORT_HEIGHT}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
            <div class="wof-card-meta wof-card-meta--compact">
              <span class="wof-host">{entry.hostname}</span>
              <span class="wof-stat">{statLabel(entry)}</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  )}
</section>

<style>
  .wall-of-fame {
    --wof-chrome: #161616;
    border-top: 1px solid var(--border);
    padding: 5rem 6vw;
  }

  .wall-of-fame-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .wall-of-fame-sub {
    margin: 0.75rem auto 0;
    max-width: 32rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .wof-featured {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    align-items: start;
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto 1.5rem;
  }

  .wof-more {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: start;
    gap: 1rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .wof-card {
    margin: 0;
    min-width: 0;
  }

  .wof-card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    transition: border-color 0.12s;
  }

  .wof-card-link:hover {
    text-decoration: none;
    border-color: var(--border-hi);
  }

  .wof-browser {
    display: flex;
    flex-direction: column;
    min-height: 0;
    background: var(--wof-chrome);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.35);
  }

  .wof-browser-chrome {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.65rem;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, #1e1e1e 0%, var(--wof-chrome) 100%);
    flex-shrink: 0;
  }

  .wof-browser--compact .wof-browser-chrome {
    padding: 0.45rem 0.55rem;
    gap: 0.5rem;
  }

  .wof-browser-dots {
    display: flex;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .wof-browser--compact .wof-browser-dots {
    gap: 0.28rem;
  }

  .wof-browser-dots span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }

  .wof-browser--compact .wof-browser-dots span {
    width: 7px;
    height: 7px;
  }

  .wof-browser-dots span:nth-child(1) {
    background: #ff5f57;
  }
  .wof-browser-dots span:nth-child(2) {
    background: #febc2e;
  }
  .wof-browser-dots span:nth-child(3) {
    background: #28c840;
  }

  .wof-browser-url {
    flex: 1;
    min-width: 0;
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.02em;
    color: var(--muted);
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--border);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .wof-browser--compact .wof-browser-url {
    font-size: 0.58rem;
    padding: 0.28rem 0.5rem;
  }

  /* Match capture width; height follows image (same as interstitial preview). */
  .wof-shot {
    background: #000;
    line-height: 0;
  }

  .wof-shot img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
    vertical-align: middle;
  }

  .wof-card--featured .wof-shot img {
    max-height: min(56rem, 80vh);
  }

  .wof-card--more .wof-shot img {
    max-height: min(40rem, 58vh);
  }

  .wof-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.65rem 0.85rem;
    border-top: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 0.72rem;
  }

  .wof-card-meta--compact {
    padding: 0.5rem 0.65rem;
    font-size: 0.68rem;
  }

  .wof-host {
    color: var(--text);
    font-weight: 700;
    letter-spacing: 0.03em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .wof-stat {
    flex-shrink: 0;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .wof-featured {
      grid-template-columns: 1fr;
    }
    .wof-more {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .wall-of-fame {
      padding: 3rem 1.5rem;
    }
    .wof-more {
      grid-template-columns: 1fr;
    }
  }
</style>
