---
import HeaderAuth from '../components/HeaderAuth.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Hide the marketing footer (e.g. on public profile pages). */
  bareFooter?: boolean;
  /** Hide the top menu bar entirely (e.g. public profile pages — Linktree-style). */
  bareHeader?: boolean;
}

const { title = 'thelnk.is — One link for everything', description = 'Turn your bio link into a storefront, a feed, and a home for everything you make. Live in minutes, yours forever.', bareFooter = false, bareHeader = false } = Astro.props;
const siteUrl = 'https://thelnk.is';

let headerUserId: string | null = null;
try {
  headerUserId = (await Astro.locals.auth()).userId ?? null;
} catch {
  headerUserId = null;
}
const isSignedIn = headerUserId !== null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#100f0d" />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="thelnk.is" />
    <meta property="og:image" content="https://thelnk.is/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://thelnk.is/og.png" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "thelnk.is",
      "url": siteUrl,
      "description": description,
      "applicationCategory": "SocialNetworkingApplication",
      "operatingSystem": "Web",
      "offers": [{ "@type": "Offer", "name": "Free", "price": "0", "priceCurrency": "USD" }]
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="512x512" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alexandria:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="shell">
      {!bareHeader && (
        <header class="top">
          <a class="brand" href="/" aria-label="thelnk.is home">thelnk<span class="dot">.is</span></a>
          <div class="auth">
            <slot name="auth">
              <HeaderAuth />
            </slot>
            {isSignedIn ? (
              <a class="auth-dashboard-link" href="/dashboard" title="Manage your page">Dashboard</a>
            ) : (
              <a class="btn-primary" href="/onboarding">Claim your link</a>
            )}
          </div>
        </header>
      )}
      <main class="main">
        <slot />
      </main>
      {!bareFooter && (
        <footer class="foot">
          <span class="foot-brand">thelnk<span class="dot">.is</span></span>
          <span class="foot-slogan">One link for everything.</span>
          <nav class="foot-nav" aria-label="Footer">
            <a href="/changelog">Changelog</a>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
          </nav>
        </footer>
      )}
    </div>
  </body>
</html>
