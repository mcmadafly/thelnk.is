---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

let clerkUserId: string | null = null;
try {
  clerkUserId = (await Astro.locals.auth()).userId ?? null;
} catch {
  clerkUserId = null;
}

if (!clerkUserId) {
  return Astro.redirect('/sign-in');
}

const profile = await env.DB.prepare(
  `SELECT username, display_name FROM profiles WHERE clerk_user_id = ?`,
)
  .bind(clerkUserId)
  .first<{ username: string; display_name: string | null }>();

if (!profile) {
  return Astro.redirect('/onboarding');
}

const origin = env.PUBLIC_APP_ORIGIN.replace(/\/+$/, '');
const publicUrl = `${origin}/${profile.username}`;
const publicUrlDisplay = publicUrl.replace(/^https?:\/\//, '');
---

<BaseLayout title="Dashboard · thelnk.is">
  <section class="dash">
    <header class="dash-head">
      <p class="dash-kicker">Your page is live</p>
      <h1>thelnk<span class="dot">.is</span>/{profile.username}</h1>
    </header>

    <div class="dash-card">
      <span class="dash-label">Public link</span>
      <div class="dash-link-row">
        <a class="dash-link-url" href={`/${profile.username}`}>{publicUrlDisplay}</a>
        <button id="copy-url" type="button" class="dash-copy" data-url={publicUrl}>Copy</button>
      </div>
      <a class="btn-primary dash-view" href={`/${profile.username}`} target="_blank" rel="noopener noreferrer">View public page ↗</a>
    </div>

    <div class="dash-card">
      <span class="dash-label">Coming soon</span>
      <ul class="dash-soon">
        <li>Add &amp; reorder your links</li>
        <li>Upload a profile photo &amp; cover</li>
        <li>Edit your display name &amp; bio</li>
        <li>Sell products, tickets &amp; tips</li>
      </ul>
    </div>
  </section>

  <script is:inline>
    (function () {
      var btn = document.getElementById('copy-url');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var url = btn.getAttribute('data-url') || '';
        if (!navigator.clipboard) return;
        navigator.clipboard.writeText(url).then(function () {
          var prev = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(function () { btn.textContent = prev || 'Copy'; }, 1600);
        });
      });
    })();
  </script>
</BaseLayout>

<style>
  .dash { max-width: 600px; margin: 0 auto; padding: clamp(2rem, 6vw, 3.5rem) 1.25rem; }
  .dash-head { margin-bottom: 1.5rem; }
  .dash-kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .dash-head h1 {
    margin: 0.45rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.1rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .dash-head .dot { color: var(--accent); }
  .dash-card {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    padding: 1.35rem 1.45rem;
    margin-bottom: 1.1rem;
  }
  .dash-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-3);
    margin-bottom: 0.85rem;
  }
  .dash-link-row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1.1rem; }
  .dash-link-url { flex: 1; font-weight: 700; font-size: 1.05rem; color: var(--text); word-break: break-all; }
  .dash-link-url:hover { color: var(--accent); }
  .dash-copy { flex-shrink: 0; padding: 0.5rem 1rem; font-size: 0.85rem; font-weight: 600; }
  .dash-view { width: 100%; padding: 0.8rem; }
  .dash-soon { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.65rem; }
  .dash-soon li { font-size: 0.95rem; color: var(--muted); display: flex; align-items: center; gap: 0.65rem; }
  .dash-soon li::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
</style>
