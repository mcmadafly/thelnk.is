---
import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { canonicalSlugForPath } from '../../lib/resolve-link-slug';
import { isValidSlug } from '../../lib/slug';

export const prerender = false;

const raw = Astro.params.slug;
if (!raw || !isValidSlug(raw)) {
  return Astro.redirect('/', 302);
}

const slug = await canonicalSlugForPath(env.DB, raw);
if (!slug) {
  return Astro.redirect('/', 302);
}

const row = await env.DB.prepare(
  `SELECT type, original_filename, mime, size_bytes, created_at, use_count, max_uses FROM links WHERE slug = ?`,
)
  .bind(slug)
  .first<{
    type: string;
    original_filename: string | null;
    mime: string | null;
    size_bytes: number;
    created_at: number;
    use_count: number;
    max_uses: number;
  }>();

if (!row || String(row.type ?? '').toLowerCase() !== 'file') {
  return Astro.redirect('/', 302);
}

function formatBytes(n: number): string {
  if (n < 1024) return `${n} B`;
  const kb = n / 1024;
  if (kb < 1024) return `${kb < 10 ? kb.toFixed(1) : Math.round(kb)} KB`;
  const mb = kb / 1024;
  return `${mb < 10 ? mb.toFixed(1) : Math.round(mb)} MB`;
}

const title = row.original_filename ?? 'Download';
const created = new Date(row.created_at * 1000).toLocaleString();
const capped = row.max_uses >= 0;
const atLimit = capped && row.use_count >= row.max_uses;
const usesLine = capped ? `${row.use_count} / ${row.max_uses} downloads used` : `${row.use_count} downloads (unlimited plan)`;
---

<BaseLayout title={`${title} · thelnk`} description="Secure download from thelnk.">
  <section class="panel download-block">
    <div class="download-hero">
      <h1>{row.original_filename ?? 'Your file'}</h1>
      <p>Hosted on thelnk · link-only access</p>
    </div>
    <div class="dl-meta">
      <div><span class="k">Type</span> {row.mime ?? '—'}</div>
      <div><span class="k">Size</span> {formatBytes(row.size_bytes)}</div>
      <div><span class="k">Created</span> {created}</div>
      <div><span class="k">Uses</span> {usesLine}</div>
    </div>
    <div class="dl-actions">
      {atLimit ? (
        <p class="limit-note">
          Download limit reached. <a href="/">Sign in on thelnk</a> and upgrade for unlimited file links.
        </p>
      ) : (
        <a class="button" href={`/api/download/${encodeURIComponent(slug)}`}>
          Download file
        </a>
      )}
      <a class="button secondary" href="/">Create your own</a>
    </div>
  </section>
</BaseLayout>

<style>
  .download-block {
    max-width: 520px;
    margin: 3.5rem auto;
    padding: 0 1.5rem;
  }
  .dl-meta .k {
    color: var(--muted);
    margin-right: 0.35rem;
  }
  .limit-note {
    margin: 0;
    color: var(--danger, #f87171);
    font-size: 0.95rem;
    max-width: 22rem;
    text-align: center;
  }
</style>
