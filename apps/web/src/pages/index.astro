---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcon from '../components/SocialIcon.astro';

const creatorAvatars = ['creator-1', 'creator-2', 'creator-3', 'creator-4'];

export const prerender = false;

let clerkUserId: string | null = null;
try {
  clerkUserId = (await Astro.locals.auth()).userId ?? null;
} catch {
  clerkUserId = null;
}

let myUsername: string | null = null;
if (clerkUserId) {
  const row = await env.DB.prepare(`SELECT username FROM profiles WHERE clerk_user_id = ?`)
    .bind(clerkUserId)
    .first<{ username: string }>();
  myUsername = row?.username ?? null;
}

const origin = env.PUBLIC_APP_ORIGIN.replace(/\/+$/, '');
const host = origin.replace(/^https?:\/\//, '');
const isSignedIn = clerkUserId !== null;
---

<BaseLayout>
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="hero-copy">
      <span class="badge"><span class="badge-dot"></span>The all-in-one creator link</span>
      <h1 class="hero-title">Link. Sell. Post.<br/>All from <span class="hl">one link.</span></h1>
      <p class="hero-sub">Turn your bio link into a storefront, a feed, and a home for everything you make — live in minutes, yours forever.</p>

      {myUsername ? (
        <div class="hero-actions">
          <a class="btn-primary hero-cta" href="/builder">Open your builder</a>
          <p class="hero-meta">Your page: <a href={`/${myUsername}`}>{host}/{myUsername}</a></p>
        </div>
      ) : isSignedIn ? (
        <a class="btn-primary hero-cta" href="/onboarding">Claim your username</a>
      ) : (
        <form class="claim-bar" action="/sign-up" method="get">
          <span class="claim-bar-prefix">{host}/</span>
          <input class="claim-bar-input" name="u" type="text" placeholder="yourname" autocomplete="off" autocapitalize="off" spellcheck="false" aria-label="Choose your username" />
          <button class="btn-primary claim-bar-btn" type="submit">Claim</button>
        </form>
      )}

      <div class="social-proof">
        <div class="avatars" aria-hidden="true">
          {creatorAvatars.map((f) => (
            <span style={`background:url('/demo/${f}.jpg') center/cover no-repeat, linear-gradient(135deg,#f97316,#d946ef)`}></span>
          ))}
        </div>
        <span class="social-proof-text">Join the creators building on thelnk.is</span>
      </div>
    </div>

    <!-- Phone preview -->
    <div class="hero-phone-wrap" aria-hidden="true">
      <div class="phone">
        <div class="phone-screen">
          <div class="phone-notch"></div>
          <div class="phone-cover"></div>
          <div class="phone-head">
            <div class="phone-avatar" style="background:url('/demo/maya.jpg') center/cover no-repeat, linear-gradient(135deg,#f97316,#d946ef);"></div>
            <div class="phone-name">Maya Chen</div>
            <div class="phone-bio">Founder · ex-FAANG · building in public</div>
            <div class="phone-socials"><span><SocialIcon name="x" size={12} /></span><span><SocialIcon name="github" size={14} /></span><span><SocialIcon name="bluesky" size={13} /></span><span><SocialIcon name="threads" size={13} /></span></div>
          </div>
          <div class="phone-featured">
            <div class="phone-featured-kicker">Now shipping</div>
            <div class="phone-featured-title">thelnk.is v0.1</div>
          </div>
          <div class="phone-links">
            <div class="phone-link"><span>Read the build log</span><span class="arr">↗</span></div>
            <div class="phone-link"><span>Follow on Bluesky</span><span class="arr">↗</span></div>
            <div class="phone-link"><span>Star thelnk.is on GitHub</span><span class="arr">↗</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Persist the typed username across the Clerk sign-up round-trip so onboarding can prefill it.
    const bar = document.querySelector<HTMLFormElement>('.claim-bar');
    const barInput = bar?.querySelector<HTMLInputElement>('.claim-bar-input');
    if (bar && barInput) {
      bar.addEventListener('submit', () => {
        const v = barInput.value.trim().toLowerCase();
        if (v) {
          try { localStorage.setItem('thelnk_pending_username', v); } catch {}
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .hero {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(2.5rem, 7vw, 5.5rem) clamp(1.25rem, 5vw, 3.5rem) clamp(3rem, 8vw, 6rem);
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    align-items: center;
    gap: clamp(2rem, 6vw, 4rem);
  }
  .hero-glow {
    position: absolute;
    top: -200px;
    left: 55%;
    transform: translateX(-50%);
    width: 1100px;
    max-width: 120vw;
    height: 900px;
    background: var(--glow);
    pointer-events: none;
    z-index: 0;
  }
  .hero-copy { position: relative; z-index: 1; }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-soft);
    padding: 9px 15px;
    border-radius: var(--radius-pill);
  }
  .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.6rem, 6vw, 3.9rem);
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: var(--text);
    margin: 1.5rem 0 0;
  }
  .hero-title .hl { color: var(--accent); }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.55;
    color: var(--muted);
    max-width: 28rem;
    margin: 1.4rem 0 0;
  }

  .hero-actions { display: flex; flex-direction: column; gap: 0.85rem; align-items: flex-start; }
  .hero-cta { margin-top: 2rem; padding: 0.9rem 1.6rem; font-size: 1rem; }
  .hero-meta { margin: 0; font-size: 0.88rem; color: var(--muted); }
  .hero-meta a { color: var(--accent); font-weight: 600; }

  /* Claim bar */
  .claim-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    padding: 8px 8px 8px 18px;
    max-width: 440px;
    margin: 2.1rem 0 0;
  }
  .claim-bar:focus-within { border-color: var(--accent); }
  .claim-bar-prefix { font-weight: 500; font-size: 1rem; color: var(--muted-3); white-space: nowrap; user-select: none; }
  .claim-bar-input {
    flex: 1; min-width: 0;
    border: none !important; background: transparent;
    padding: 0.55rem 0; font-weight: 600; font-size: 1rem;
    box-shadow: none !important;
  }
  .claim-bar-input:focus { box-shadow: none !important; border: none !important; }
  .claim-bar-btn { flex-shrink: 0; padding: 0.8rem 1.5rem; border-radius: 10px; }

  .social-proof { display: flex; align-items: center; gap: 14px; margin-top: 1.75rem; }
  .avatars { display: flex; }
  .avatars span {
    width: 34px; height: 34px; border-radius: 50%;
    border: 2px solid var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    color: #fff;
  }
  .avatars span + span { margin-left: -12px; }
  .social-proof-text { font-weight: 500; font-size: 0.86rem; color: var(--muted-2); }

  /* ── Phone ── */
  .hero-phone-wrap { position: relative; z-index: 1; display: flex; justify-content: center; }
  .phone {
    width: 286px;
    height: 580px;
    background: #0a0907;
    border: 1px solid var(--border-hi);
    border-radius: 42px;
    padding: 11px;
    box-shadow: var(--shadow-lg);
  }
  .phone-screen { height: 100%; background: var(--bg); border-radius: 31px; overflow: hidden; position: relative; }
  .phone-notch { position: absolute; top: 11px; left: 50%; transform: translateX(-50%); width: 96px; height: 24px; background: #0a0907; border-radius: 14px; z-index: 2; }
  .phone-cover { height: 144px; background: linear-gradient(180deg, rgba(16,15,13,0) 55%, var(--bg) 100%), linear-gradient(135deg, #f97316 0%, #d946ef 60%, #6d28d9 100%); }
  .phone-head { text-align: center; margin-top: -36px; position: relative; padding: 0 18px; }
  .phone-avatar { width: 66px; height: 66px; border-radius: 50%; margin: 0 auto; border: 3px solid var(--bg); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 700; font-size: 1.6rem; color: #fff; }
  .phone-name { font-family: var(--font-display); font-weight: 700; font-size: 19px; color: var(--text); margin-top: 11px; }
  .phone-bio { font-weight: 500; font-size: 11px; color: var(--muted-2); margin-top: 7px; }
  .phone-socials { display: flex; justify-content: center; gap: 8px; margin-top: 13px; }
  .phone-socials span {
    width: 30px; height: 30px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,.14);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-weight: 700; font-size: 8px; color: #cfc9bf;
  }
  .phone-featured { margin: 18px 18px 0; background: var(--accent); border-radius: var(--link-radius); padding: 13px 15px; }
  .phone-featured-kicker { font-family: var(--font-mono); font-weight: 700; font-size: 8px; color: #fff; letter-spacing: 0.12em; text-transform: uppercase; }
  .phone-featured-title { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: #fff; margin-top: 7px; }
  .phone-links { padding: 11px 18px 0; display: flex; flex-direction: column; gap: 9px; }
  .phone-link {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--link-radius); padding: 13px 15px;
    font-weight: 600; font-size: 12px; color: var(--text-dim);
  }
  .phone-link .arr { color: var(--muted-3); }

  @media (max-width: 860px) {
    .hero { grid-template-columns: 1fr; text-align: center; }
    .hero-copy { display: flex; flex-direction: column; align-items: center; }
    .hero-sub { margin-left: auto; margin-right: auto; }
    .hero-actions { align-items: center; }
    .badge { align-self: center; }
    .hero-phone-wrap { order: 1; }
    .hero-glow { top: -300px; }
  }
</style>
