---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Show, SignInButton, SignUpButton, UserButton } from '@clerk/astro/components';
---

<BaseLayout title="thelnk · Short links & file sharing">
  <div slot="auth" class="auth-slot">
    <Show when="signed-in">
      <UserButton />
    </Show>
    <Show when="signed-out">
      <span class="auth-login-wrap"><SignInButton mode="modal" /></span>
      <span class="auth-upgrade-wrap"><SignUpButton mode="modal" /></span>
    </Show>
  </div>

  <section class="hero" id="hero">

    <div class="hero-copy">
      <p class="hero-kicker">— URL shortener &amp; file drops</p>
      <h1 class="hero-title">Share<br/>any&shy;thing.</h1>
      <p class="hero-sub">Shorten any URL. Drop any file.<br/>No account needed. Free forever.</p>
      <div class="trust-row">
        <span>Instant</span>
        <span class="trust-sep">×</span>
        <span>Anonymous</span>
        <span class="trust-sep">×</span>
        <span>Free</span>
      </div>
    </div>

    <div class="tool-card">

      <!-- Segmented control -->
      <div class="seg-track" role="tablist">
        <button class="seg-btn active" role="tab" data-tab="url" aria-selected="true" aria-controls="panel-url">[ LINK ]</button>
        <button class="seg-btn" role="tab" data-tab="file" aria-selected="false" aria-controls="panel-file">[ FILE ]</button>
      </div>

      <!-- URL panel -->
      <div id="panel-url" class="tool-panel" role="tabpanel">
        <form id="form-url" class="url-form" novalidate>
          <input
            id="targetUrl"
            name="targetUrl"
            type="text"
            placeholder="https://example.com/some/long/url"
            required
            autocomplete="off"
            spellcheck="false"
          />
          <button type="submit" id="btn-url" class="btn-primary submit-btn" aria-live="polite">
            Shorten
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </button>
        </form>
        <div id="out-url" class="result-wrapper">
          <div class="result-inner">
            <div class="result-box">
              <div class="result-row">
                <a class="result-url" href="#" target="_blank" rel="noopener noreferrer"></a>
                <button class="copy-btn" type="button" aria-label="Copy link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="9" y="9" width="13" height="13" rx="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- File panel -->
      <div id="panel-file" class="tool-panel hidden" role="tabpanel">
        <input id="file" name="file" type="file" class="sr-only" />
        <div id="drop-zone" class="drop-zone">
          <div class="dz-icon-wrap" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
          </div>
          <p class="dz-label">Drop a file here</p>
          <p class="dz-hint">or <span class="browse-text">browse to upload</span></p>
        </div>
        <div id="file-ready" class="file-ready" hidden>
          <div class="file-ready-meta">
            <span id="file-name" class="file-name-text"></span>
            <svg class="file-ready-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
              <polyline points="13 2 13 9 20 9"/>
            </svg>
            <button id="clear-file" class="clear-btn" type="button" aria-label="Remove">×</button>
          </div>
          <button id="btn-file" class="btn-primary submit-btn file-upload-btn" type="button">
            Upload &amp; share
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </button>
        </div>
        <div id="out-file" class="result-wrapper">
          <div class="result-inner">
            <div class="result-box">
              <div class="result-row">
                <a class="result-url" href="#" target="_blank" rel="noopener noreferrer"></a>
                <button class="copy-btn" type="button" aria-label="Copy link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="9" y="9" width="13" height="13" rx="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

  </section>

  <!-- Trust marquee (hidden) -->
  <section class="trust trust--hidden" aria-label="Used by teams at leading startups">
    <p class="trust-label">Used by teams at</p>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        <span>Stripe</span><span class="sep">×</span>
        <span>Vercel</span><span class="sep">×</span>
        <span>Linear</span><span class="sep">×</span>
        <span>Figma</span><span class="sep">×</span>
        <span>Notion</span><span class="sep">×</span>
        <span>Loom</span><span class="sep">×</span>
        <span>Airtable</span><span class="sep">×</span>
        <span>Supabase</span><span class="sep">×</span>
        <span>Resend</span><span class="sep">×</span>
        <span>PlanetScale</span><span class="sep">×</span>
        <span>Retool</span><span class="sep">×</span>
        <span>Brex</span><span class="sep">×</span>
        <span>Railway</span><span class="sep">×</span>
        <span>Clerk</span><span class="sep">×</span>
        <span>Anthropic</span><span class="sep">×</span>
        <!-- duplicate for seamless loop -->
        <span>Stripe</span><span class="sep">×</span>
        <span>Vercel</span><span class="sep">×</span>
        <span>Linear</span><span class="sep">×</span>
        <span>Figma</span><span class="sep">×</span>
        <span>Notion</span><span class="sep">×</span>
        <span>Loom</span><span class="sep">×</span>
        <span>Airtable</span><span class="sep">×</span>
        <span>Supabase</span><span class="sep">×</span>
        <span>Resend</span><span class="sep">×</span>
        <span>PlanetScale</span><span class="sep">×</span>
        <span>Retool</span><span class="sep">×</span>
        <span>Brex</span><span class="sep">×</span>
        <span>Railway</span><span class="sep">×</span>
        <span>Clerk</span><span class="sep">×</span>
        <span>Anthropic</span><span class="sep">×</span>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing" id="pricing">
    <div class="pricing-header">
      <p class="section-kicker">— Pricing</p>
      <h2 class="section-title">Simple, honest pricing.</h2>
    </div>
    <div class="pricing-grid">
      <div class="plan free">
        <p class="plan-label">Free</p>
        <div class="plan-price">
          <span class="price-value">$0</span>
        </div>
        <p class="plan-tagline">No credit card. No account required.</p>
        <ul class="plan-features">
          <li>URL shortening</li>
          <li>File sharing</li>
          <li>10 successful uses per link</li>
          <li>No calendar expiry (fair use)</li>
        </ul>
        <button type="button" class="plan-cta" id="plan-cta-free">Get started free →</button>
      </div>
      <div class="plan paid monthly">
        <p class="plan-label">Pro</p>
        <div class="plan-price">
          <span class="price-was" aria-hidden="true">$9.99</span>
          <span class="price-value price-value--accent">$4.99</span>
          <span class="price-period">/ mo</span>
        </div>
        <p class="plan-tagline">Unlimited uses while subscribed. Cancel anytime.</p>
        <ul class="plan-features">
          <li>Everything in Free</li>
          <li>Unlimited successful uses per link</li>
          <li>Billed monthly via Stripe</li>
        </ul>
        <button type="button" class="plan-cta btn-primary" id="plan-cta-monthly">Subscribe →</button>
      </div>
      <div class="plan paid lifetime">
        <p class="plan-label">Lifetime</p>
        <div class="plan-price">
          <span class="price-was" aria-hidden="true">$100</span>
          <span class="price-value">$75</span>
          <span class="price-once">once</span>
        </div>
        <p class="plan-tagline">Pay once, own forever on your account.</p>
        <ul class="plan-features">
          <li>Everything in Free</li>
          <li>Unlimited successful uses per link</li>
          <li>No recurring charges</li>
        </ul>
        <button type="button" class="plan-cta" id="plan-cta-lifetime">Get lifetime access →</button>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="faq-header">
      <p class="section-kicker">— FAQ</p>
      <h2 class="section-title">Common questions.</h2>
    </div>
    <div class="faq-list">
      <details class="faq-item">
        <summary>How many uses does a free link get?</summary>
        <p>Free links are limited to <strong>10 successful uses</strong> per link. After that, the link stops working. <strong>Pro</strong> (monthly) or <strong>Lifetime</strong> unlocks unlimited uses for links you create while your plan is active.</p>
      </details>
      <details class="faq-item">
        <summary>How long do links stay active?</summary>
        <p>
          We do not enforce a fixed calendar expiry today. Free and anonymous links are capped at
          <strong>10 successful uses</strong> per link (redirects for URLs, completed downloads for files). Pro and Lifetime
          remove that cap for links you create while your plan is active.
        </p>
      </details>
      <details class="faq-item">
        <summary>Do I need an account to use thelnk.is?</summary>
        <p>
          No account needed for free use. Sign in with Clerk to subscribe to Pro or buy Lifetime — checkout must be tied to an
          account so we can upgrade the right profile.
        </p>
      </details>
      <details class="faq-item">
        <summary>What is the difference between Pro monthly and Lifetime?</summary>
        <p>
          <strong>Pro monthly</strong> is a recurring subscription through Stripe — unlimited per-link uses while your
          subscription is active; cancel anytime. <strong>Lifetime</strong> is a single payment for the same unlimited
          benefit without a monthly bill, for the operational lifetime of the service (see Terms).
        </p>
      </details>
      <details class="faq-item">
        <summary>What file types can I share?</summary>
        <p>Any file type is supported — images, documents, archives, videos. Files are stored securely and served via a short link identical to a shortened URL.</p>
      </details>
    </div>
  </section>

</BaseLayout>

<script>
  await new Promise<void>(resolve => {
    if (document.readyState !== 'loading') resolve();
    else document.addEventListener('DOMContentLoaded', () => resolve(), { once: true });
  });

  // Tabs
  const segBtns = document.querySelectorAll<HTMLButtonElement>('.seg-btn');
  const panelUrl = document.getElementById('panel-url')!;
  const panelFile = document.getElementById('panel-file')!;
  segBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const t = btn.dataset.tab;
      segBtns.forEach(b => {
        b.classList.toggle('active', b.dataset.tab === t);
        b.setAttribute('aria-selected', String(b.dataset.tab === t));
      });
      panelUrl.classList.toggle('hidden', t !== 'url');
      panelFile.classList.toggle('hidden', t !== 'file');
    });
  });

  const CHECK_ICON = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`;
  const COPY_ICON = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;

  function shortUrlForDisplay(full: string): string {
    return full.replace(/^https?:\/\//i, '');
  }

  function showResult(wrapper: HTMLElement, text: string, isErr: boolean) {
    const inner = wrapper.querySelector<HTMLElement>('.result-box');
    const row = wrapper.querySelector<HTMLElement>('.result-row');
    const u = wrapper.querySelector<HTMLAnchorElement>('.result-url');
    const c = wrapper.querySelector<HTMLElement>('.copy-btn');
    if (u) {
      u.href = isErr ? '#' : text;
      u.textContent = isErr ? text : shortUrlForDisplay(text);
    }
    if (c) c.style.display = isErr ? 'none' : '';
    if (inner) inner.classList.toggle('err', isErr);
    if (row) {
      if (isErr) row.classList.remove('highlighted');
      else {
        row.classList.remove('highlighted');
        row.offsetHeight;
        row.classList.add('highlighted');
      }
    }
    wrapper.classList.add('visible');
  }

  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const link = btn.closest('.result-box')?.querySelector<HTMLAnchorElement>('.result-url');
      const hrefAttr = link?.getAttribute('href') ?? '';
      const toCopy = /^https?:\/\//i.test(hrefAttr) ? hrefAttr : (link?.textContent ?? '');
      navigator.clipboard?.writeText(toCopy).then(() => {
        btn.innerHTML = CHECK_ICON;
        (btn as HTMLElement).style.color = '#4ade80';
        (btn as HTMLElement).style.borderColor = 'rgba(74,222,128,0.4)';
        (btn as HTMLElement).style.background = 'rgba(74,222,128,0.12)';
        setTimeout(() => {
          btn.innerHTML = COPY_ICON;
          (btn as HTMLElement).style.color = '';
          (btn as HTMLElement).style.borderColor = '';
          (btn as HTMLElement).style.background = '';
        }, 1800);
      });
    });
  });

  document.getElementById('plan-cta-free')?.addEventListener('click', () => {
    document.getElementById('hero')?.scrollIntoView({ behavior: 'smooth' });
    document.getElementById('targetUrl')?.focus();
  });

  async function startCheckout(tier: 'monthly' | 'lifetime', btn: HTMLButtonElement) {
    btn.disabled = true;
    try {
      const res = await fetch('/api/billing/checkout', {
        method: 'POST',
        credentials: 'include',
        headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
        body: JSON.stringify({ tier }),
      });
      const data = (await res.json()) as { url?: string; error?: string };
      if (data.url) {
        window.location.href = data.url;
        return;
      }
      alert(data.error ?? `Checkout failed (${res.status})`);
    } catch {
      alert('Network error starting checkout');
    } finally {
      btn.disabled = false;
    }
  }

  document.getElementById('plan-cta-monthly')?.addEventListener('click', function (this: HTMLButtonElement) {
    void startCheckout('monthly', this);
  });
  document.getElementById('plan-cta-lifetime')?.addEventListener('click', function (this: HTMLButtonElement) {
    void startCheckout('lifetime', this);
  });

  // URL shortener
  const formUrl = document.getElementById('form-url');
  const outUrl = document.getElementById('out-url');
  const btnUrl = document.getElementById('btn-url');

  if (formUrl instanceof HTMLFormElement && outUrl && btnUrl instanceof HTMLButtonElement) {
    formUrl.addEventListener('submit', async e => {
      e.preventDefault();
      outUrl.classList.remove('visible');
      const targetUrlInput = formUrl.querySelector<HTMLInputElement>('#targetUrl');
      const targetUrl = String(new FormData(formUrl).get('targetUrl') ?? '').trim();
      if (!targetUrl) {
        targetUrlInput?.focus();
        return;
      }

      const orig = btnUrl.innerHTML;
      btnUrl.disabled = true;
      btnUrl.classList.add('is-loading');
      btnUrl.setAttribute('aria-busy', 'true');
      btnUrl.innerHTML =
        '<span class="btn-url-spin" aria-hidden="true"></span><span class="btn-url-loading-text">Shortening…</span>';
      await new Promise<void>(r => requestAnimationFrame(() => requestAnimationFrame(() => r())));
      try {
        const res = await fetch('/api/links/url', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ targetUrl }),
        });
        const data = (await res.json().catch(() => ({}))) as {
          shortUrl?: string; error?: string; detail?: string; reason?: string;
        };
        if (!res.ok) {
          const base = data.error ?? res.statusText;
          const bits = [data.reason, data.detail].filter(Boolean);
          showResult(outUrl, bits.length ? `${base} — ${bits.join(' — ')}` : base, true);
        } else {
          showResult(outUrl, data.shortUrl ?? 'Created', false);
        }
      } finally {
        btnUrl.disabled = false;
        btnUrl.classList.remove('is-loading');
        btnUrl.removeAttribute('aria-busy');
        btnUrl.innerHTML = orig;
      }
    });
  }

  // File upload
  const fileInput = document.getElementById('file') as HTMLInputElement;
  const dropZone = document.getElementById('drop-zone')!;
  const fileReady = document.getElementById('file-ready')!;
  const fileNameEl = document.getElementById('file-name')!;
  const clearFile = document.getElementById('clear-file')!;
  const btnFile = document.getElementById('btn-file') as HTMLButtonElement;
  const outFile = document.getElementById('out-file')!;
  let selectedFile: File | null = null;

  function setFile(f: File | null) {
    selectedFile = f;
    outFile.classList.remove('visible');
    if (f) { fileNameEl.textContent = f.name; dropZone.hidden = true; fileReady.hidden = false; }
    else { dropZone.hidden = false; fileReady.hidden = true; fileInput.value = ''; }
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault(); dropZone.classList.remove('drag-over');
    const f = e.dataTransfer?.files[0]; if (f) setFile(f);
  });
  fileInput.addEventListener('change', () => { const f = fileInput.files?.[0]; if (f) setFile(f); });
  clearFile.addEventListener('click', () => setFile(null));

  btnFile.addEventListener('click', async () => {
    const file = selectedFile; if (!file) return;
    outFile.classList.remove('visible');
    const orig = btnFile.innerHTML;
    btnFile.disabled = true; btnFile.textContent = 'Uploading…';
    try {
      const initRes = await fetch('/api/uploads/init', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename: file.name, contentType: file.type || 'application/octet-stream', size: file.size }),
      });
      const init = (await initRes.json().catch(() => ({}))) as {
        uploadUrl?: string; r2Key?: string; contentType?: string; size?: number; filename?: string; error?: string;
      };
      if (!initRes.ok) { showResult(outFile, init.error ?? initRes.statusText, true); return; }
      const putRes = await fetch(init.uploadUrl!, {
        method: 'PUT', headers: { 'Content-Type': (init.contentType ?? file.type) || 'application/octet-stream' }, body: file,
      });
      if (!putRes.ok) { showResult(outFile, `Upload failed (${putRes.status})`, true); return; }
      const doneRes = await fetch('/api/uploads/complete', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ r2Key: init.r2Key, filename: init.filename ?? file.name, contentType: (init.contentType ?? file.type) || 'application/octet-stream', size: init.size ?? file.size }),
      });
      const done = (await doneRes.json().catch(() => ({}))) as {
        shortUrl?: string; error?: string; detail?: string; reason?: string;
      };
      if (!doneRes.ok) {
        const base = done.error ?? doneRes.statusText;
        const bits = [done.reason, done.detail].filter(Boolean);
        showResult(outFile, bits.length ? `${base} — ${bits.join(' — ')}` : base, true);
      } else {
        setFile(null);
        showResult(outFile, done.shortUrl ?? 'Created', false);
      }
    } finally { btnFile.disabled = false; btnFile.innerHTML = orig; }
  });
</script>

<style>
  .auth-slot { display: flex; align-items: center; gap: 0.5rem; }


  /* ── Hero ── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
  }

  .hero-copy {
    padding: 5rem 4vw 4rem 6vw;
    border-right: 1px solid var(--border);
    position: sticky;
    top: 52px;
  }

  .hero-kicker {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin: 0 0 2rem;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(4.5rem, 9vw, 8rem);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 0 0 2.5rem;
    color: var(--text);
  }

  .hero-sub {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.75;
    margin: 0 0 3rem;
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    font-family: var(--mono);
  }

  .trust-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .trust-sep { color: var(--accent); }

  /* ── Tool card ── */
  .tool-card {
    padding: 3.5rem 5vw 3rem 4vw;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 52px;
  }

  /* Tabs */
  .seg-track {
    display: flex;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.75rem;
  }
  .seg-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.5rem 0.6rem 0;
    margin-right: 1.5rem;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    background: transparent;
    color: var(--muted);
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.1s, border-color 0.1s;
  }
  .seg-btn.active { color: var(--text); border-bottom-color: var(--accent); }
  .seg-btn:hover:not(.active) { color: var(--text); }

  .tool-panel.hidden { display: none; }

  /* URL form */
  .url-form { display: flex; flex-direction: column; gap: 0.5rem; }

  .submit-btn {
    width: 100%;
    justify-content: center;
    padding: 0.85rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  #btn-url.is-loading {
    pointer-events: none;
  }
