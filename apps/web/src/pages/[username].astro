---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/profile.css';
import { validateUsername } from '../lib/username';
import { themeStyle } from '../lib/themes';
import { renderProfileHTML, type RenderItem } from '../lib/profile-render';

export const prerender = false;

type ProfileRow = {
  id: number; username: string; display_name: string | null; subtitle: string | null;
  bio: string | null; avatar_r2_key: string | null; background_image_r2_key: string | null;
  theme: string;
};

// Defense in depth: reserved/invalid segment can never resolve a profile.
const check = validateUsername(Astro.params.username ?? '');
if (!check.ok) return new Response('Not found', { status: 404 });

const profile = await env.DB.prepare(
  `SELECT id, username, display_name, subtitle, bio, avatar_r2_key, background_image_r2_key, theme
   FROM profiles WHERE username = ? COLLATE NOCASE`,
).bind(check.username).first<ProfileRow>();
if (!profile) return new Response('Not found', { status: 404 });

// Single ordered list: links + socials interleaved by the creator's chosen order.
const itemRows = (await env.DB.prepare(
  `SELECT type, title, url, is_featured FROM profile_links
   WHERE profile_id = ? AND is_visible = 1
   ORDER BY sort_order ASC, id ASC`,
).bind(profile.id).all<{ type: string; title: string; url: string; is_featured: number }>()).results ?? [];

const items: RenderItem[] = itemRows.map((r) =>
  r.type === 'social'
    ? { type: 'social', name: r.title, url: r.url }
    : { type: 'link', title: r.title, url: r.url, featured: !!r.is_featured },
);

const mediaUrl = (key: string | null): string | null =>
  !key ? null : /^(https?:)?\//.test(key) ? key : `/api/media/${key}`;

const displayName = profile.display_name?.trim() || profile.username;
const bgUrl = mediaUrl(profile.background_image_r2_key);
const bioStyle = bgUrl
  ? `${themeStyle(profile.theme)};background:linear-gradient(rgba(0,0,0,.4),rgba(0,0,0,.4)),url('${bgUrl}') center/cover`
  : themeStyle(profile.theme);

const innerHtml = renderProfileHTML({
  username: profile.username,
  displayName,
  subtitle: profile.subtitle,
  bio: profile.bio,
  avatarSrc: mediaUrl(profile.avatar_r2_key),
  items,
});

const pageTitle = `${displayName} · thelnk.is`;
const pageDesc = profile.bio?.trim() || `${displayName} on thelnk.is`;
---

<BaseLayout title={pageTitle} description={pageDesc} bareFooter={true} bareHeader={true}>
  <section class={`bio${bgUrl ? ' has-bg' : ''}`} style={bioStyle}>
    <div class="bio-cover" aria-hidden="true"></div>
    <div class="bio-inner" set:html={innerHtml}></div>
  </section>
</BaseLayout>
