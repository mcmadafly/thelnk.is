{
  "name": "thelnk",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:web": "bun run --cwd apps/web dev",
    "build:web": "bun run --cwd apps/web build",
    "migrate": "bun run --cwd apps/web migrate",
    "db:migrate:local": "bun run --cwd apps/web db:migrate:local",
    "db:migrate:remote": "bun run --cwd apps/web db:migrate:remote",
    "types:web": "bun run --cwd apps/web generate-types",
    "check:web": "bun run --cwd apps/web check"
  }
}
